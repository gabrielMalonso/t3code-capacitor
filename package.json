{
  "name": "t3code-capacitor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build:web": "node scripts/sync-web.mjs",
    "sync:android": "pnpm build:web && cap sync android",
    "build:android": "pnpm sync:android && cd android && JAVA_HOME=/opt/homebrew/opt/openjdk@21 ./gradlew assembleDebug",
    "install:tablet": "pnpm build:android && adb -s RX2XC0094TX install -r android/app/build/outputs/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "@capacitor/android": "8.4.2",
    "@capacitor/core": "8.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.2"
  }
}
